---
import { asset } from '@/utils/url';
import { site } from '@/data/site';

const title = `${site.name} — ${site.tagline}`;
const description = site.tagline;
const videoSrc = asset('/videos/intro.MOV');
const videoSrcMobile = asset('/videos/intro-mobile.mp4');
const homeHref = asset('/home');
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/jpeg" href={asset('/favicon.jpg')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://www.youtube.com" />
    <link rel="preconnect" href="https://s.ytimg.com" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <script async src="https://www.youtube.com/iframe_api" data-yt-api></script>
  </head>
  <body>
    <main class="gate" data-home-href={homeHref}>
      <video
        class="gate__video"
        autoplay
        muted
        playsinline
        webkit-playsinline
        preload="auto"
        disablepictureinpicture
        disableremoteplayback
        aria-hidden="true"
      >
        <source src={videoSrcMobile} media="(max-width: 900px)" type="video/mp4" />
        <source src={videoSrc} type="video/quicktime" />
      </video>

      <div class="gate__halves" role="group" aria-label="Seçimini yap">
        <button type="button" class="half half--red" data-choice="red" aria-label="Gerçeği gör"></button>
        <button type="button" class="half half--blue" data-choice="blue" aria-label="Uykuya dön"></button>
      </div>

      <div class="red-wipe" aria-hidden="true">
        <span class="red-wipe__panel red-wipe__panel--top"></span>
        <span class="red-wipe__panel red-wipe__panel--bottom"></span>
      </div>

      <div class="blue-wipe" aria-hidden="true">
        <span class="blue-wipe__panel"></span>
        <span class="blue-wipe__panel"></span>
        <span class="blue-wipe__panel"></span>
        <span class="blue-wipe__panel"></span>
        <span class="blue-wipe__panel"></span>
      </div>

      <div class="blackout" aria-hidden="true">
        <p class="blackout__text" data-type="çok yazık..."><span class="blackout__prompt">&gt;</span><span class="blackout__typed"></span></p>
      </div>
    </main>

    <script>
      import { initIntroMusic, handoffIntroMusic, destroyIntroMusic } from '@/scripts/intro-music';

      const main = document.querySelector<HTMLElement>('.gate');
      if (main) {
        const homeHref = main.dataset.homeHref || '/';

        const redWipe = main.querySelector<HTMLElement>('.red-wipe');
        const blueWipe = main.querySelector<HTMLElement>('.blue-wipe');
        const blackout = main.querySelector<HTMLElement>('.blackout');

        initIntroMusic();

        main.addEventListener('click', (event) => {
          const target = (event.target as HTMLElement).closest<HTMLElement>('[data-choice]');
          if (!target || main.classList.contains('is-locked')) return;
          const choice = target.dataset.choice;
          main.classList.add('is-locked');

          if (choice === 'red') {
            if (redWipe) {
              requestAnimationFrame(() => redWipe.classList.add('is-active'));
            }
            try {
              sessionStorage.setItem('rp_entering', '1');
            } catch {}
            handoffIntroMusic(350);
            window.setTimeout(() => { window.location.href = homeHref; }, 600);
          } else {
            blueWipe?.classList.add('is-active');
            destroyIntroMusic();
            window.setTimeout(() => {
              blackout?.classList.add('is-active');
              const textEl = blackout?.querySelector<HTMLElement>('.blackout__text');
              const typedEl = blackout?.querySelector<HTMLElement>('.blackout__typed');
              if (textEl && typedEl) {
                const full = textEl.dataset.type || '';
                const chars = Array.from(full);
                let i = 0;
                const tick = () => {
                  if (i >= chars.length) return;
                  const ch = chars[i++];
                  if (ch === '.') {
                    const dotEl = document.createElement('span');
                    dotEl.className = 'blackout__dot';
                    dotEl.textContent = ch;
                    typedEl.appendChild(dotEl);
                  } else {
                    typedEl.appendChild(document.createTextNode(ch));
                  }
                  window.setTimeout(tick, 180);
                };
                window.setTimeout(tick, 400);
              }
            }, 900);
          }
        });

        const video = main.querySelector<HTMLVideoElement>('.gate__video');
        if (video) {
          // iOS Safari is strict: set muted state on the element directly,
          // not just via attribute, before any play() attempt.
          video.muted = true;
          video.defaultMuted = true;
          (video as any).playsInline = true;

          const tryPlay = () => {
            const p = video.play();
            if (p && typeof p.catch === 'function') {
              p.catch(() => {
                // If autoplay is blocked, kick it off on the first user gesture.
                const start = () => {
                  video.muted = true;
                  video.play().catch(() => {});
                  document.removeEventListener('touchstart', start);
                  document.removeEventListener('pointerdown', start);
                  document.removeEventListener('click', start);
                };
                document.addEventListener('touchstart', start, { passive: true, once: true });
                document.addEventListener('pointerdown', start, { passive: true, once: true });
                document.addEventListener('click', start, { once: true });
              });
            }
          };

          if (video.readyState >= 2) {
            tryPlay();
          } else {
            video.addEventListener('loadeddata', tryPlay, { once: true });
            video.addEventListener('canplay', tryPlay, { once: true });
            tryPlay();
          }

          video.addEventListener('ended', () => {
            try {
              video.pause();
              video.currentTime = Math.max(0, video.duration - 0.05);
            } catch {}
          });
          document.addEventListener('visibilitychange', () => {
            if (!document.hidden && !video.ended) tryPlay();
          });
        }

        window.setTimeout(() => {
          main.classList.add('is-text-gone');
        }, 28000);
      }
    </script>

    <style is:global>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        height: 100dvh;
        background: #fff;
        color: #fff;
        font-family: 'Geist Variable', 'Geist', system-ui, -apple-system, 'Segoe UI', sans-serif;
        overflow: hidden;
        overscroll-behavior: none;
      }

      *, *::before, *::after { box-sizing: border-box; }

      .gate {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        overflow: hidden;
        background: #fff;
      }

      .gate__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        pointer-events: none;
      }
      .gate__halves {
        position: absolute;
        inset: 0;
        z-index: 2;
        display: flex;
      }
      .half {
        flex: 1;
        position: relative;
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
      }
      .half:focus-visible { outline: none; }

      /* Red pill wipe: instant cover (no open animation) — home's entry handles the reveal */
      .red-wipe {
        position: fixed;
        inset: 0;
        z-index: 60;
        pointer-events: none;
        overflow: hidden;
        opacity: 0;
        transition: opacity 0.25s ease;
      }
      .red-wipe__panel {
        position: absolute;
        left: 0;
        right: 0;
        height: 50%;
      }
      .red-wipe__panel--top {
        top: 0;
        background: linear-gradient(0deg, #ff2a2a 0%, #c40000 40%, #5a0000 100%);
      }
      .red-wipe__panel--bottom {
        bottom: 0;
        background: linear-gradient(180deg, #ff2a2a 0%, #c40000 40%, #5a0000 100%);
      }
      .red-wipe.is-active { opacity: 1; }

      /* Blue pill panels drop from top, stagger */
      .blue-wipe {
        position: fixed;
        inset: 0;
        display: flex;
        z-index: 60;
        pointer-events: none;
      }
      .blue-wipe__panel {
        flex: 1;
        height: 100%;
        background: linear-gradient(180deg, #1a4bff 0%, #2a6bff 60%, #0a2a9e 100%);
        transform: translateY(-101%);
        transition: transform 0.9s cubic-bezier(0.77, 0, 0.18, 1);
        will-change: transform;
      }
      .blue-wipe.is-active .blue-wipe__panel { transform: translateY(0); }
      .blue-wipe.is-active .blue-wipe__panel:nth-child(1) { transition-delay: 0s; }
      .blue-wipe.is-active .blue-wipe__panel:nth-child(2) { transition-delay: 0.08s; }
      .blue-wipe.is-active .blue-wipe__panel:nth-child(3) { transition-delay: 0.16s; }
      .blue-wipe.is-active .blue-wipe__panel:nth-child(4) { transition-delay: 0.24s; }
      .blue-wipe.is-active .blue-wipe__panel:nth-child(5) { transition-delay: 0.32s; }

      /* Black end card — fades in on top of the blue panels */
      .blackout {
        position: fixed;
        inset: 0;
        background: #000;
        display: flex;
        align-items: flex-start;
        justify-content: flex-start;
        padding: clamp(1.2rem, 2.4vw, 2.4rem);
        opacity: 0;
        transition: opacity 0.9s ease;
        z-index: 70;
        pointer-events: none;
      }
      .blackout.is-active { opacity: 1; pointer-events: auto; }
      .blackout__text {
        margin: 0;
        color: #00ff41;
        font-family: ui-monospace, 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
        font-weight: 300;
        font-size: clamp(1.6rem, 2.6vw, 2.8rem);
        letter-spacing: 0.02em;
        text-shadow:
          0 0 4px rgba(0, 255, 65, 0.55),
          0 0 12px rgba(0, 255, 65, 0.3);
        max-width: 100%;
        overflow-wrap: anywhere;
      }
      .blackout__prompt { margin-right: 0.35ch; }
      .blackout__dot {
        font-size: 0.7em;
        font-weight: 200;
        letter-spacing: 0.06em;
        vertical-align: 0.05em;
      }
      .blackout__text::after {
        content: '';
        display: inline-block;
        width: 0.12em;
        height: 1em;
        background: #00ff41;
        margin-left: 0.05em;
        vertical-align: -0.12em;
        box-shadow: 0 0 8px rgba(0, 255, 65, 0.8);
        animation: blackout-caret 0.8s step-end infinite;
      }
      @keyframes blackout-caret {
        0%, 50%   { opacity: 1; }
        50.01%, 100% { opacity: 0; }
      }

      /* 28s timer: fade out all gate text. Only applies to intro page. */
      .gate.is-text-gone .blackout__text {
        opacity: 0;
        transition: opacity 1.2s ease;
        pointer-events: none;
      }

      @media (prefers-reduced-motion: reduce) {
        .half::before { transition: none; }
        .red-wipe, .blue-wipe__panel, .blackout, .blackout__text { transition: none; }
      }
    </style>
  </body>
</html>
