---
import Base from '@/layouts/Base.astro';
import ProjectGrid from '@/components/ProjectGrid.astro';
import { projects } from '@/data/projects';
import { site } from '@/data/site';
---
<Base title={`Projects — ${site.name}`} description={`Selected work by ${site.name}`}
      nextPost={{ label: 'Next up', title: 'About', href: '/about' }}>
  <section class="post-hero">
    <div class="container" data-reveal>
      <div class="eyebrow" style="margin-bottom: 2rem;">(Projects)</div>
      <h1 class="post-hero__title">All work.<br/>{projects.length} selected.</h1>
    </div>
  </section>

  <ProjectGrid items={projects} heading="Every case study" />
</Base>
