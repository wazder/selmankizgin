---
import { site } from '@/data/site';
---
<footer class="cta-footer">
  <a class="cta-footer__mail" href={`mailto:${site.email}`} data-cursor="-pointer">{site.email}</a>

  <div class="cta-footer__bottom">
    <div class="cta-footer__contact">
      <span class="cta-footer__location">{site.location}</span>
      <span class="cta-footer__sep">·</span>
      <a href={`mailto:${site.email}`} class="cta-footer__contact-mail">{site.email}</a>
    </div>

    <div class="cta-footer__socials">
      {site.socials.map((s, i) => (
        <>
          {i > 0 && <span class="cta-footer__sep">/</span>}
          <a href={s.href} target="_blank" rel="noopener" data-cursor="-pointer">{s.label}</a>
        </>
      ))}
    </div>

    <div class="cta-footer__copy">
      &copy; {new Date().getFullYear()} {site.name}
    </div>
  </div>
</footer>
