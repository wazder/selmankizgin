---
import { site } from '@/data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
let path = Astro.url.pathname.replace(/\/$/, '');
if (base && path.startsWith(base)) path = path.slice(base.length);
if (!path) path = '/';
---
<header class="header">
  <div class="header__left">
    <div class="header__swap" aria-live="polite">
      <span class="header__swap-item header__greeting" data-greeting>Gerçek dünyaya hoş geldin.</span>
      <a class="header__swap-item header__name" href={`${base}/home`} data-cursor="-pointer">{site.firstName} {site.lastName}</a>
    </div>
    <div class="music-widget" data-music-widget data-ready="false" data-playing="false" data-muted="false" aria-label="Now playing">
      <button type="button" class="music-widget__toggle" data-music-toggle data-cursor="-pointer" aria-label="Mute / unmute">
        <span class="music-widget__bars" aria-hidden="true">
          <span></span><span></span><span></span><span></span>
        </span>
      </button>
      <span class="music-widget__title" data-music-title>Şu an çalıyor</span>
      <input
        type="range"
        class="music-widget__slider"
        data-music-volume
        min="0"
        max="100"
        step="1"
        value="8"
        aria-label="Ses seviyesi"
      />
    </div>
  </div>

  <nav class="header__socials" aria-label="Socials">
    <span>Socials</span>
    {site.socials.map((s, i) => (
      <>
        <span class="slash">/</span>
        <a href={s.href} target="_blank" rel="noopener" data-cursor="-pointer" data-cursor-text={s.label}>{s.short}</a>
      </>
    ))}
  </nav>

  <div class="header__right">
    <nav class="header__nav" aria-label="Main">
      {site.nav.map((n, i) => (
        <>
          {i > 0 && <span class="slash">/</span>}
          <a href={`${base}${n.href}`} aria-current={path === n.href ? 'page' : undefined}>{n.label}</a>
        </>
      ))}
    </nav>
    <a class="header__cta" href={`${base}/home#signup`} data-signup-link data-cursor="-pointer">Erken erişim</a>
  </div>
</header>

<script>
  document.addEventListener('click', (event) => {
    const link = (event.target as HTMLElement).closest<HTMLAnchorElement>('[data-signup-link]');
    if (!link) return;
    const url = new URL(link.href, location.href);
    if (url.pathname === location.pathname && url.hash) {
      event.preventDefault();
      const target = document.querySelector<HTMLElement>(url.hash);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  });
</script>
