---
import { asset } from '@/utils/url';
---
<div class="hero-bg" data-hero-bg aria-hidden="true">
  <div class="hero-bg__layer hero-bg__layer--bg">
    <img
      src={asset('/images/bg.webp')}
      alt=""
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="hero-bg__layer hero-bg__layer--char" data-hero-bg-char>
    <img
      src={asset('/images/char.png')}
      alt=""
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="hero-bg__overlay"></div>
</div>
