---
import { testimonials } from '@/data/projects';
---
<section class="testi container">
  <h2 class="section-title" data-reveal>
    <span>Birlikte çalıştığım insanlar</span>{' '}
    <span class="muted">ne düşünüyor?</span>{' '}
    <span class="muted">(Testimonials)</span>
  </h2>

  <ul class="testi__list">
    {testimonials.map((t, i) => (
      <li class="testi__slide" data-reveal>
        <div class="testi__index">{String(i + 1).padStart(2, '0')} / {String(testimonials.length).padStart(2, '0')}</div>
        <div class="testi__body">
          <blockquote class="testi__quote">
            {t.quote.map((p) => <p>{p}</p>)}
          </blockquote>
          <div class="testi__author">
            <strong>{t.author}</strong>
            <span aria-hidden="true">·</span>
            <span>{t.role}</span>
          </div>
        </div>
      </li>
    ))}
  </ul>
</section>
