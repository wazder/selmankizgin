<div class="red-entry" data-entry aria-hidden="true">
  <span class="red-entry__panel red-entry__panel--top"></span>
  <span class="red-entry__panel red-entry__panel--bottom"></span>
</div>

<style is:global>
  .red-entry {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    overflow: hidden;
    display: none;
  }
  .red-entry.is-ready { display: block; }
  .red-entry__panel {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    transform: translateY(0);
    transition: transform 1.1s cubic-bezier(0.77, 0, 0.18, 1);
    will-change: transform;
  }
  .red-entry__panel--top {
    top: 0;
    background: linear-gradient(0deg, #ff2a2a 0%, #c40000 40%, #5a0000 100%);
  }
  .red-entry__panel--bottom {
    bottom: 0;
    background: linear-gradient(180deg, #ff2a2a 0%, #c40000 40%, #5a0000 100%);
  }
  .red-entry.is-opening .red-entry__panel--top { transform: translateY(-100%); }
  .red-entry.is-opening .red-entry__panel--bottom { transform: translateY(100%); }
</style>

<script>
  try {
    if (sessionStorage.getItem('rp_entering') === '1') {
      sessionStorage.removeItem('rp_entering');
      const entry = document.querySelector<HTMLElement>('[data-entry]');
      if (entry) {
        entry.classList.add('is-ready');
        window.requestAnimationFrame(() => {
          window.setTimeout(() => entry.classList.add('is-opening'), 120);
        });
        window.setTimeout(() => entry.remove(), 1600);
      }
    }
  } catch {}
</script>
