---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import HeroBackground from '@/components/HeroBackground.astro';
import RedWipeEntry from '@/components/RedWipeEntry.astro';
import NextPost from '@/components/NextPost.astro';
import Footer from '@/components/Footer.astro';
import { asset } from '@/utils/url';

type Props = {
  title: string;
  description?: string;
  nextPost?: { label: string; title: string; href: string };
  hideFooter?: boolean;
};

const {
  title,
  description = 'Portfolio template — mock content, swap with your own.',
  nextPost,
  hideFooter = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
let pathname = Astro.url.pathname.replace(/\/$/, '');
if (base && pathname.startsWith(base)) pathname = pathname.slice(base.length);
if (!pathname) pathname = '/';
const isHome = pathname === '/home';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href={asset('/favicon.svg')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body data-home={isHome ? 'true' : 'false'}>
    <RedWipeEntry />
    {isHome && <HeroBackground />}
    <div class="grain-overlay" aria-hidden="true"></div>
    <Header />
    <main class="transition-fade" data-swup-transition="page">
      <slot />
      {nextPost && <NextPost {...nextPost} />}
      {!hideFooter && <Footer />}
    </main>

    <script>
      import '@/scripts/boot';
    </script>
  </body>
</html>
