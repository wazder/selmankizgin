---
import { site } from '@/data/site';
---
<section class="intro container" data-reveal>
  <div>
    <div class="intro__eyebrow">(Intro)</div>
  </div>
  <div class="intro__body">
    {site.description}{' '}
    <span class="highlight">{site.ctaLead}</span>
  </div>

  <div class="intro__awards">
    <div class="intro__awards-head">
      <div class="eyebrow">Bu eğitimde neler öğreneceksin?</div>
      <div class="muted">{site.modules.length} modül</div>
    </div>
    <ul class="intro__awards-list">
      {site.modules.map(m => (
        <li class="award-row" data-cursor="-pointer">
          <span class="award-row__year">{m.id}</span>
          <span class="award-row__name">{m.name}</span>
          <span class="award-row__category">{m.body}</span>
          <span class="award-row__mark">↗</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    <span>AI Prompt Engineering</span>
    <span>AI Influencer</span>
    <span>Sinematik Görsel</span>
    <span>Content Monetization</span>
    <span>Dropshipping</span>
    <span>AI Prompt Engineering</span>
    <span>AI Influencer</span>
    <span>Sinematik Görsel</span>
    <span>Content Monetization</span>
    <span>Dropshipping</span>
  </div>
</div>
